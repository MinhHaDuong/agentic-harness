{
  "env": {
    "UV_ENV_FILE": "/home/haduong/.claude/.env"
  },
  "permissions": {
    "allow": [
      "EnterWorktree",
      "ExitWorktree",
      "Bash(git fetch *)",
      "Bash(git rebase *)",
      "Bash(git checkout *)",
      "Bash(git add *)",
      "Bash(git commit -m ' *)",
      "Bash(git push *)",
      "Bash(gh repo *)",
      "Bash(gh api *)",
      "Edit(/.claude/skills/start-ticket/**)",
      "Bash(uv sync *)",
      "Bash(git merge *)"
    ]
  },
  "model": "sonnet",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/scripts/on-start.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/scripts/guard-destructive-bash.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash(git commit*)",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/scripts/guard-commit-on-main.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash(gh pr merge*)",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/scripts/block-pr-merge-in-worktree.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/scripts/lint-on-edit.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": []
  },
  "effortLevel": "xhigh",
  "advisorModel": "opus",
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "skipDangerousModePermissionPrompt": true
}
